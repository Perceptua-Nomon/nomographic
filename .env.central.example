# nomographic central database environment variables
# Copy to .env.central and fill in values: cp .env.central.example .env.central
# Used by: scripts/migrate-central.sh, scripts/init-db.sh (central/all), scripts/seed-central.sh
# docker compose reads this via --env-file .env.central
# .env.central is gitignored — never commit secrets or credentials here.

# --- ArcadeDB Server ---
# WARNING: Change this before ANY non-local deployment!
# Generate a strong password and NEVER commit it to source control.
# Quote passwords that contain shell special characters (& ! $ etc.).
ARCADEDB_ROOT_PASSWORD='changeme_before_deploy'

# Hostname of the ArcadeDB server (central instance).
ARCADEDB_HOST=localhost

# HTTP API port (REST, Studio UI).
ARCADEDB_HTTP_PORT=2480

# Binary protocol port (JDBC driver).
ARCADEDB_BINARY_PORT=2424

# --- init-db.sh ---
# Maximum health-check retries before giving up.
INIT_DB_RETRIES=30

# Seconds between health-check retries.
INIT_DB_RETRY_DELAY=2
