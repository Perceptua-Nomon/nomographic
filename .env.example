# ArcadeDB configuration for nomon databases.
# Copy to .env and adjust as needed: cp .env.example .env

# --- ArcadeDB Server ---
# WARNING: Change this before ANY non-local deployment!
# Generate a strong password and NEVER commit it to source control.
# Quote passwords that contain shell special characters (& ! $ etc.).
ARCADEDB_ROOT_PASSWORD='changeme_before_deploy'

# Hostname of the ArcadeDB server (central instance).
ARCADEDB_HOST=localhost

# SSH host for Raspberry Pi access.
# Preferred variable for deploy scripts:
NOMON_PI_HOST=perceptua@perceptua

# Backward-compatible SSH host alias used by scripts/deploy-local.sh.
PI_HOST=perceptua@perceptua

# Optional path to an SSH private key for deploy scripts.
# NOMON_SSH_KEY=~/.ssh/id_ed25519

# Optional remote path to the nomographic repo on the Pi.
# NOMON_REMOTE_DIR=~/perceptua-nomon/nomographic

# Optional sudo password used by scripts/deploy-local.sh for non-interactive
# remote sudo operations when passwordless sudo is not configured.
# Leave empty to use interactive sudo prompts.
# NOMON_SUDO_PASS=

# Snapshot local DB data before deploy rollback-sensitive operations.
# 1 = enabled (default), 0 = disabled.
NOMOGRAPHIC_LOCAL_DB_SNAPSHOT=1

# HTTP API port (REST, Studio UI).
ARCADEDB_HTTP_PORT=2480

# Binary protocol port (JDBC driver).
ARCADEDB_BINARY_PORT=2424

# --- Local Embedded Database ---
# Filesystem path for the local embedded ArcadeDB data directory.
# For Pi local service deploys, prefer an absolute path such as
# /var/lib/nomographic/local-db.
ARCADEDB_LOCAL_DATA=local/data

# Local database name used by scripts/migrate-local.sh.
ARCADEDB_LOCAL_DB=nomon_local

# Local DB host and auth used when LOCAL_MIGRATOR_USE_RUNNING_SERVICE=1.
ARCADEDB_LOCAL_HOST=127.0.0.1
ARCADEDB_LOCAL_HTTP_PORT=2482
# ARCADEDB_LOCAL_ROOT_PASSWORD='changeme_before_deploy'

# --- Local Pi Service Runtime (deploy-local allowlist source) ---
# These values are used by scripts/deploy-local.sh to build the allowlisted
# payload installed to /etc/nomographic/local-db.env on Pi.
# Namespace: LOCAL_ARCADEDB_* (shared local runtime defaults)
# Scope: running local DB service + baseline defaults for migrate-local.sh.

# Local ArcadeDB image used by the Pi systemd service.
LOCAL_ARCADEDB_IMAGE=arcadedata/arcadedb:latest

# Local-only service ports bound to loopback on the Pi.
LOCAL_ARCADEDB_HTTP_PORT=2482
LOCAL_ARCADEDB_BINARY_PORT=2425

# Root password used by the Pi local ArcadeDB service API.
# Baseline for scripts/migrate-local.sh auth unless overridden by
# ARCADEDB_LOCAL_ROOT_PASSWORD or by -Darcadedb.server.rootPassword embedded
# in LOCAL_MIGRATOR_JAVA_OPTS (temporary-container mode).
LOCAL_ARCADEDB_ROOT_PASSWORD='changeme_before_deploy'

# Optional memory tuning passed to ARCADEDB_OPTS_MEMORY in the Pi service.
# Also used by scripts/migrate-local.sh for the temporary migrator container.
LOCAL_ARCADEDB_OPTS_MEMORY=''

# --- Local Migration Runner (ArcadeDB API) ---
# Namespace: LOCAL_MIGRATOR_* (temporary migrator behavior controls only)
# Scope: only scripts/migrate-local.sh temporary container behavior.
# Important: LOCAL_MIGRATOR_* is never exported by deploy-local.sh into
# /etc/nomographic/local-db.env.

# Temporary ArcadeDB image used to run local embedded migrations.
LOCAL_MIGRATOR_IMAGE=arcadedata/arcadedb:latest

# HTTP port exposed by the temporary local migrator container.
LOCAL_MIGRATOR_HTTP_PORT=2481

# JVM options passed to the temporary local migrator container.
# Password precedence in temporary-container mode:
# 1) baseline: LOCAL_ARCADEDB_ROOT_PASSWORD
# 2) override: ARCADEDB_LOCAL_ROOT_PASSWORD
# 3) highest precedence: -Darcadedb.server.rootPassword in
#    LOCAL_MIGRATOR_JAVA_OPTS
# If all are unset, migrate-local.sh falls back to testpassword.
# Example override: LOCAL_MIGRATOR_JAVA_OPTS='-Xms128m -Xmx384m -Darcadedb.server.rootPassword=override_password'
LOCAL_MIGRATOR_JAVA_OPTS=''

# Startup readiness retry settings for the temporary local migrator.
LOCAL_MIGRATOR_STARTUP_RETRIES=30
LOCAL_MIGRATOR_STARTUP_DELAY=1

# Set to 1 to run migrations against an already-running local DB service
# instead of starting a temporary migrator container.
LOCAL_MIGRATOR_USE_RUNNING_SERVICE=0

# --- init-db.sh ---
# Maximum health-check retries before giving up.
INIT_DB_RETRIES=30

# Seconds between health-check retries.
INIT_DB_RETRY_DELAY=2
